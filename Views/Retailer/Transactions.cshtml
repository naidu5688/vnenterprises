        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
        padding: 0 6px;
    }

    /* footer */
    .modal-footer {
        text-align: right;
        margin-top: 15px;
        position: sticky;
        bottom: 0;
        padding-top: 10px;
    }

</style>

